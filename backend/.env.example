# Server
PORT=3101
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=debug

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=devpulse
DB_USER=postgres
DB_PASSWORD=
DB_TABLE_PREFIX=devpulse_

# Auth (true = Keycloak, false = single-tenant без авторизации, LLM отключён)
AUTH_ENABLED=true

# Keycloak (требуется только при AUTH_ENABLED=true)
KEYCLOAK_URL=http://localhost:8083
KEYCLOAK_REALM=office
KEYCLOAK_CLIENT_ID=devpulse-api
KEYCLOAK_CLIENT_SECRET=

# Keycloak Internal (для LLM)
KEYCLOAK_INTERNAL_REALM=internalApi
KEYCLOAK_INTERNAL_CLIENT_ID=api2api
KEYCLOAK_INTERNAL_CLIENT_SECRET=

# YouTrack (по паттерну YOUTRACK_<ID>_URL/TOKEN/NAME)
YOUTRACK_DRCS_URL=http://localhost:8082
YOUTRACK_DRCS_TOKEN=
YOUTRACK_DRCS_NAME=YouTrack ДРКС

# Дополнительные инстансы (раскомментировать при необходимости)
# YOUTRACK_2024_URL=http://localhost:8084
# YOUTRACK_2024_TOKEN=
# YOUTRACK_2024_NAME=YouTrack 2024

# LLM (Ollama)
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=gemma3:4b
LLM_TEMPERATURE=0.3
LLM_RATE_LIMIT=3

# Cron
CRON_ENABLED=true
CRON_SCHEDULE=0 0 * * 1
